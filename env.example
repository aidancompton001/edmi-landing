# ═══════════════════════════════════════════
# EDMI Microscope Store — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in real values

# ── WooCommerce (edmi.com.ua) ──────────────
# Get from: WooCommerce → Settings → Advanced → REST API
WC_URL=https://edmi.com.ua
WC_CONSUMER_KEY=ck_your_key_here
WC_CONSUMER_SECRET=cs_your_secret_here
WC_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Database ───────────────────────────────
DATABASE_URL=postgresql://edmi:password@localhost:5432/edmi_app
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────
JWT_SECRET=change_this_to_a_random_string_64_chars
JWT_EXPIRES_IN=7d

# ── LiqPay (ПриватБанк) ───────────────────
# Get from: https://www.liqpay.ua/en/adminbusiness
# USE THE SAME KEYS AS ON THE WEBSITE!
LIQPAY_PUBLIC_KEY=sandbox_your_public_key
LIQPAY_PRIVATE_KEY=sandbox_your_private_key

# ── WayForPay (alternative) ────────────────
# Get from: https://merchant.wayforpay.com/
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_account
WAYFORPAY_MERCHANT_SECRET=your_merchant_secret
WAYFORPAY_MERCHANT_DOMAIN=edmi.com.ua

# ── Nova Poshta ────────────────────────────
# Get from: https://new.novaposhta.ua/ → Settings → API
NOVA_POSHTA_API_KEY=your_nova_poshta_api_key

# ── Anthropic (AI Assistant) ───────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Firebase (Push Notifications) ──────────
# Get from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=edmi-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@edmi-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── App Config ─────────────────────────────
API_URL=http://localhost:3000
APP_ENV=development
PORT=3000
